<Window x:Class="OpenGLOpt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenGLOpt"
        xmlns:views="clr-namespace:OpenGLOpt.Views"
        mc:Ignorable="d"
        Title="OpenGL Optimization - GLWpfControl + MVVM" Height="800" Width="1200">
    
    <!-- Resources must be defined before they are used -->
    <Window.Resources>
        <local:BoolToToggleTextConverter x:Key="BoolToToggleTextConverter"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Main OpenGL Rendering Area -->
        <views:LayeredOpenGLControl x:Name="OpenGLControl" Grid.Row="0"/>
        
        <!-- Control Panel -->
        <Border Grid.Row="1" Background="#2D2D30" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                
                <!-- Particle Count Control -->
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="Particle Count: " VerticalAlignment="Center" Foreground="White" Margin="0,0,5,0"/>
                    <Slider x:Name="ParticleCountSlider" 
                           Minimum="1000" 
                           Maximum="1000000" 
                           Value="{Binding ParticleCount, Mode=TwoWay}" 
                           Width="200"
                           VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ParticleCount, StringFormat='{}{0:N0}'}" 
                              VerticalAlignment="Center" 
                              Foreground="White" 
                              MinWidth="80"
                              Margin="5,0,0,0"/>
                </StackPanel>
                
                <!-- FPS Display -->
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="FPS: " VerticalAlignment="Center" Foreground="White" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding CurrentFps, StringFormat='{}{0:F1}'}" 
                              VerticalAlignment="Center" 
                              Foreground="#4CAF50" 
                              FontWeight="Bold"
                              MinWidth="50"/>
                </StackPanel>
                
                <!-- Control Buttons -->
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <Button Content="Reset Particles" 
                           Command="{Binding ResetParticlesCommand}"
                           Margin="0,0,10,0"
                           Padding="15,5"
                           Background="#007ACC"
                           Foreground="White"
                           BorderThickness="0"/>
                    <Button Content="{Binding IsRenderingEnabled, Converter={StaticResource BoolToToggleTextConverter}}" 
                           Command="{Binding ToggleRenderingCommand}"
                           Padding="15,5"
                           Background="#FF6B6B"
                           Foreground="White"
                           BorderThickness="0"/>
                </StackPanel>
                
                <!-- Status Message -->
                <TextBlock Text="{Binding StatusMessage}" 
                          VerticalAlignment="Center" 
                          Foreground="#FFC107" 
                          FontStyle="Italic"/>
                
            </StackPanel>
        </Border>
    </Grid>
</Window>
